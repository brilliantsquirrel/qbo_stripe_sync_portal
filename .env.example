# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/qbo_stripe_sync_portal"

# ─── Auth (Auth.js / NextAuth) ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Field Encryption ─────────────────────────────────────────────────────────
# Used to encrypt QBO tokens + Stripe keys at rest in the database
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY="64-char-hex-string-here"

# ─── QBO (QuickBooks Online) OAuth ────────────────────────────────────────────
QBO_CLIENT_ID="your-intuit-client-id"
QBO_CLIENT_SECRET="your-intuit-client-secret"
QBO_REDIRECT_URI="http://localhost:3000/api/vendor/connect/qbo/callback"
# sandbox | production
QBO_ENVIRONMENT="sandbox"
# From Intuit developer portal (Webhooks tab)
QBO_WEBHOOK_VERIFIER_TOKEN="your-qbo-webhook-verifier-token"

# ─── Stripe (Platform account — vendors pay US) ────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# From Stripe Dashboard > Connect > Settings > Client ID
STRIPE_CLIENT_ID="ca_..."

# Stripe Price IDs for each vendor subscription tier
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# ─── GCP ─────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID="qbo-stripe-sync-portal"
GCP_TASKS_QUEUE="sync-jobs"
GCP_TASKS_LOCATION="us-central1"
# Full Cloud Run service URL (used by Cloud Tasks to call /api/sync/run)
GCP_SYNC_SERVICE_URL="https://your-service-url.run.app"
# Service account email with Cloud Tasks Enqueuer role
CLOUD_TASKS_OIDC_SA="sync-invoker@qbo-stripe-sync-portal.iam.gserviceaccount.com"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
